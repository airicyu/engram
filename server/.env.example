# Copy to `.env` in this directory (`server/`) and adjust.
# Bun loads `.env` automatically when you `bun run` from here.
# All vars optional — defaults match an empty local prototype.

# Memory store root (absolute or relative to cwd). Default: <repo>/data
# ENGRAM_HOME=../data

# IANA timezone for calendar days + event timestamps
# ENGRAM_TZ=Asia/Hong_Kong

# HTTP listen port
# PORT=8787

# Dream extract runner: cursor | claude | mock-ok | mock-fail
# ENGRAM_AGENT=cursor

# Binary overrides (when using the matching agent)
# CURSOR_AGENT_BIN=agent
# CLAUDE_BIN=claude

# Verbose dream extract/apply logs: set to 1
# ENGRAM_DREAM_DEBUG=1
